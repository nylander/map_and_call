// ═══════════════════════════════════════════════════════════════════════════════
//
//  map_and_call  —  Nextflow pipeline for read mapping and variant calling
//
// ═══════════════════════════════════════════════════════════════════════════════


// ───────────────────────────────────────────────────────────────────────────────
// 1. USER PARAMETERS
// ───────────────────────────────────────────────────────────────────────────────

// ── I/O ────────────────────────────────────────────────────────────────────────

params.input     = null                  // Path to input CSV (sample_id;lane;datatype;library;read_1;read_2)
params.reference = null  // Path to reference FASTA
params.name      = 'output'     // Run name — used for output directory and file naming
params.popfile   = null                  // Optional: path to population file (sample_id;population) for joint genotyping
params.reads_dir = null                  // Optional: directory to prepend to read paths in the input CSV
params.outdir    = "output"

// ── Workflow mode ───────────────────────────────────────────────────────────────

params.mapper                = 'bwa_mem'    // Read mapper: currently only 'bwa_mem' is supported
params.variant_caller        = 'bcftools'  // Variant caller: 'freebayes' or 'bcftools'
params.skip_variant_calling  = false        // Stop after BAM/CRAM processing, skipping variant calling and filtering
params.map_historical_pairs  = true         // Map paired-end reads from historical samples in addition to collapsed/singleton reads

// ── Parameters for specialized workflows ───────────────────────────────────────
// These parameters are used by specific workflow files (read_qc.nf, call_variants.nf)

params.bamfiles        = null  // Path to text file listing BAM paths (one per line) for call_variants.nf; sample IDs extracted from read groups
params.cleanreads_dir  = null  // Optional: directory containing clean reads for read_qc.nf; glob pattern: ${sample_id}*{_R1,_R2,_1,_2,_paired,_merged}*.{fq,fastq}.gz

// ── Preprocessing ───────────────────────────────────────────────────────────────

params.min_readlength = 30  // Minimum read length after trimming
params.trim_front     = 0   // Bases to hard-trim from read start (fastp)
params.trim_tail      = 0   // Bases to hard-trim from read end (fastp)

params.store_cleanreads = false  // Store trimmed/filtered reads in addition to final BAMs (takes more space, but perhaps useful for debugging and downstream analyses of unmapped reads)

params.skip_premapping_dedup = false
params.premapping_dedup = params.skip_premapping_dedup ? false : true  // Run BBMap's clumpify for deduplication before mapping (recommended if duplication levels are expected to be high)
params.skip_postmapping_dedup = false
params.postmapping_dedup = params.skip_postmapping_dedup ? false : true  // Run samtools markdup for deduplication after mapping

params.store_crams = true // Store mapped reads in CRAM format instead of BAM (saves space)

params.min_mapqual = 30
params.min_basequal = 20

params.store_sample_fastqc = true // Store FastQC reports for individual samples (in addition to the MultiQC report)

// ── Sex chromosome configuration ────────────────────────────────────────────────
// Specifying sex chromosomes enables sex-specific coverage filtering and on-the-fly
// sex assignment based on coverage ratios. Leave null if the sex system is unknown.
// X/Z are the non-sex-limited chromosomes; Y/W are the sex-limited ones.
// In X/Y systems, hemizygous coverage on X → male. In Z/W systems → female.

params.x_scaffolds = null  // Scaffold name(s) for the X chromosome
params.y_scaffolds = null  // Scaffold name(s) for the Y chromosome
params.z_scaffolds = null  // Scaffold name(s) for the Z chromosome
params.w_scaffolds = null  // Scaffold name(s) for the W chromosome

params.sex_assignment_lower_threshold = 0.25  // Coverage ratio below this → hemizygous sex call
params.sex_assignment_upper_threshold = 0.75  // Coverage ratio above this → homozygous sex call

// ── Scaffold selection ──────────────────────────────────────────────────────────
// Limit variant calling to a subset of scaffolds. Scaffolds absent from the list
// are excluded from calling but still present in CRAM files.

params.scaffold_list = null  // Path to file listing one scaffold per line; null = use all scaffolds

// ── Reference masking ───────────────────────────────────────────────────────────

params.reference_mask = null  // Optional: BED file with regions to exclude from callable sites (e.g., repeats, low-complexity)

// –– Mapping –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––
params.modern_mapper = "bwa_mem" // for now, only bwa is used here
params.short_reads_threshold = 70 // reads of this length or shorter will be mapped with bwa aln, longer reads with bwa mem; ignored if historical mapper is not set to split
params.historical_mapper = "split" // either split, bwa_mem or bwa_aln; if split, historical reads will be split into those with lengths < 70 bp and >= 70 bp and mapped with bwa aln and bwa mem, respectively
params.bwa_aln_flags = "" // optional flags to use when mapping historical/ancient samples, ignored if bwa_mem

// ── Variant calling ─────────────────────────────────────────────────────────────

params.chunk_size        = 20   // Genomic interval size for parallel calling (Mb)
params.ploidy            = 2
params.min_base_quality  = 20
params.store_raw_vcf     = true  // Keep the unfiltered VCF in the output


// ── Variant filtering ───────────────────────────────────────────────────────────
// Depth thresholds accept either:
//   - a float (e.g. 0.3)  → fraction of sample's mean autosomal depth
//   - an integer (e.g. 5) → absolute read depth
// If a fractional value evaluates to below the minimum sensible depth (1 for min,
// 2 for max), a warning is emitted and the value is clamped automatically.

params.min_depth           = 0.3    // Minimum depth to retain a genotype call
params.max_depth           = 2.0    // Maximum depth to retain a genotype call
params.maf_threshold       = 0.0    // Minor allele frequency filter (0.0 = off)
params.fmiss_threshold     = 1.0    // Maximum fraction of missing genotypes (1.0 = off)
params.min_allele_balance  = 0.15   // Minimum allele balance for heterozygous calls (minor-allele fraction)
params.min_global_dp = null // Minimum read depth across all genotypes at a sites in order to keep it
params.max_global_dp = null // Maximum read depth across all genotypes at a sites in order to keep it

// Custom hard-filter expressions; leave null to use caller-specific defaults (see Advanced section below)
params.snp_filter_expression   = null
params.indel_filter_expression = null

// ── Downsampling ────────────────────────────────────────────────────────────────

params.downsample_bams          = false  // Downsample BAMs before variant calling
params.downsample_bams_coverage = -1    // Target coverage; -1 = downsample to the shallowest sample in the dataset

// ── Historical DNA ──────────────────────────────────────────────────────────────

params.damageprofiler_rescale = false  // Rescale base qualities using mapDamage (historical samples only)


// ───────────────────────────────────────────────────────────────────────────────
// 2. ADVANCED PARAMETERS
// ───────────────────────────────────────────────────────────────────────────────

// ── Caller-specific default filter expressions ──────────────────────────────────
// These are used when the user has not provided custom filter expressions above.

params.snp_filter_expression_bcftools    = 'QUAL<30 || MQ<30'
params.indel_filter_expression_bcftools  = 'QUAL<30 || MQ<30'

params.snp_filter_expression_freebayes   = 'QUAL<30 || MQM<30 || MQMR<30'
params.indel_filter_expression_freebayes = 'QUAL<30 || MQM<30 || MQMR<30'

params.snp_filter_expression_gatk        = 'QD < 2.0 || FS > 60.0 || MQ < 40.0 || MQRankSum < -12.5 || ReadPosRankSum < -8.0'
params.indel_filter_expression_gatk      = 'QD < 2.0 || FS > 200.0 || ReadPosRankSum < -20.0'

// ── HPC account ────────────────────────────────────────────────────────────────

params.slurm_account = null  // SLURM account string for cluster execution (used by dardel profile)

// ── Resource ceilings ───────────────────────────────────────────────────────────
// Hard limits applied across all processes; individual process allocations below
// will never exceed these values.

params.max_memory = '512.GB'
params.max_cpus   = 64
params.max_time   = '96.h'

// ── Tool-specific tuning ────────────────────────────────────────────────────────

params.bwa_threads = 30  // CPU threads for BWA MEM alignment
params.clumpify_threads = 8  // CPU threads for BBMap's clumpify (deduplication)


// ───────────────────────────────────────────────────────────────────────────────
// 3. SYSTEM CONFIGURATION  (generally leave untouched)
// ───────────────────────────────────────────────────────────────────────────────

// ── Conda ───────────────────────────────────────────────────────────────────────

params.use_mamba = true
params.conda_cachedir = "$projectDir/.envs"
conda.enabled  = true
conda.cacheDir = params.conda_cachedir

// ── Output mode ─────────────────────────────────────────────────────────────────

outputDir = "${params.outdir}"
workflow.output.mode = 'copy'

// ── Per-process resource defaults ───────────────────────────────────────────────

process.cpus   = 1
process.memory = '3.GB'
process.time   = '4.h'

process {
    withName: 'fastqc' {
        cpus = 2
        time = '10.h'
    }
    withName: 'fastp' {
        cpus = 4
        time = '1.h'
    }
    withName: 'bwa_mem' {
        cpus = { params.bwa_threads }
        time = '24.h'
    }
    withName: 'bwa_index' {
        cpus = 8
        time = '24.h'
    }
    withName: 'samtools_markdups' {
        cpus = 4
        time = '24.h'
    }
    withName: 'combine_bedfiles' {
        cpus = 4
        time = '10.h'
    }
    withName: 'parse_region_depths' {
        cpus = 1
        time = '2.h'
    }
}

// ── Execution profiles ──────────────────────────────────────────────────────────

profiles {

    standard {
        process.executor = 'local'
        process {
            withName: 'fastqc'             { memory = '3.GB' }
            withName: 'fastp'              { memory = '3.GB' }
            withName: 'bwa_index'          { memory = '3.GB'; cpus = 4 }
            withName: 'bwa_mem'            { memory = '3.GB' }
            withName: 'samtools_markdups'  { memory = '3.GB' }
            withName: 'combine_bedfiles'   { memory = '3.GB' }
            withName: 'parse_region_depths'{ memory = '2.GB' }
        }
    }

    dardel {
        process.executor       = 'slurm'
        process.queue          = 'shared'
        process.clusterOptions = "-A ${params.slurm_account}"
        conda.enabled          = true
        conda.useMamba         = params.use_mamba
        conda.cacheDir         = "$projectDir/.envs"
        process {
            // for the heavy processes, specify custom sets of memory allocations
            withName: 'fastqc'              { memory = {8.GB * task.attempt} ; cpus = 8;  maxRetries = 3; errorStrategy = 'retry' }
            withName: 'fastp'               { memory = {8.GB * task.attempt} ; cpus = 8;  maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bwa_index'           { memory = 16.GB;  cpus = 8; time = { 10.h * task.attempt }; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bwa_mem'             { memory = { 128.GB * task.attempt } ; cpus = params.bwa_threads; time = 24.h; queue = { task.attempt == 1 ? 'shared' : 'memory'}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bwa_mem_singlereads' { memory = { 128.GB * task.attempt } ; cpus = params.bwa_threads; time = 24.h; queue = { task.attempt == 1 ? 'shared' : 'memory'}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'samtools_markdups'   { memory = {16.GB * task.attempt} ; cpus = { 4 * task.attempt }; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'samtools_dp'         { memory = {8.GB * task.attempt} ; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'samtools_merge'       { memory = {16.GB * task.attempt} ; cpus = 8; time = {10.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'merge_historical_bams'       { memory = {16.GB * task.attempt} ; cpus = 8; time = {10.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'freebayes'           { memory = {16.GB * task.attempt} ; time = {12.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'mpileup'              { memory = {16.GB * task.attempt} ; time = {12.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bcftools_norm'            { memory = {16.GB * task.attempt} ; time = {5.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'clumpify_single' { memory = {16.GB * task.attempt} ; cpus = 8; time = {1.h * task.attempt}; queue = 'shared'; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'clumpify_paired' { memory = {16.GB * task.attempt} ; cpus = 8; time = {1.h * task.attempt}; queue = 'shared'; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'damage_profiler_rescale' { memory = {16.GB * task.attempt} ; time = {10.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'damage_profiler' { memory = {16.GB * task.attempt} ; time = {5.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            // and then more general ones using labels for the rest
            withLabel: 'thin_short' {memory = {4.GB * task.attempt}; time = {1.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withLabel: 'thin_medium' {memory = {4.GB * task.attempt}; time = {3.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withLabel: 'medium_short' {memory = {8.GB * task.attempt}; time = {1.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withLabel: 'medium_medium' {memory = {8.GB * task.attempt}; time = {3.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
        }
    }

    pelle {
        process.executor       = 'slurm'
        process.queue          = 'pelle'
        process.clusterOptions = "-A ${params.slurm_account}"
        conda.enabled          = true
        conda.useMamba         = params.use_mamba
        conda.cacheDir         = "$projectDir/.envs"
        process {
            // for the heavy processes, specify custom sets of memory allocations
            withName: 'fastqc'              { memory = {8.GB * task.attempt} ; cpus = 8;  maxRetries = 3; errorStrategy = 'retry' }
            withName: 'fastp'               { memory = {8.GB * task.attempt} ; cpus = 8;  maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bwa_index'           { memory = 16.GB;  cpus = 8; time = { 10.h * task.attempt }; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bwa_mem'             { memory = { 128.GB * task.attempt } ; cpus = params.bwa_threads; time = 24.h; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bwa_mem_singlereads' { memory = { 128.GB * task.attempt } ; cpus = params.bwa_threads; time = 24.h; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'samtools_markdups'   { memory = {16.GB * task.attempt} ; cpus = { 4 * task.attempt }; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'samtools_dp'         { memory = {8.GB * task.attempt} ; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'samtools_merge'       { memory = {16.GB * task.attempt} ; cpus = 8; time = {10.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'merge_historical_bams'       { memory = {16.GB * task.attempt} ; cpus = 8; time = {10.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'freebayes'           { memory = {16.GB * task.attempt} ; time = {12.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'mpileup'              { memory = {16.GB * task.attempt} ; time = {12.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'bcftools_norm'            { memory = {16.GB * task.attempt} ; time = {5.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'clumpify_single' { memory = {16.GB * task.attempt} ; cpus = 8; time = {1.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'clumpify_paired' { memory = {16.GB * task.attempt} ; cpus = 8; time = {1.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'damage_profiler_rescale' { memory = {16.GB * task.attempt} ; time = {10.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withName: 'damage_profiler' { memory = {16.GB * task.attempt} ; time = {5.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            // and then more general ones using labels for the rest
            withLabel: 'thin_short' {memory = {4.GB * task.attempt}; time = {1.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withLabel: 'thin_medium' {memory = {4.GB * task.attempt}; time = {3.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withLabel: 'medium_short' {memory = {8.GB * task.attempt}; time = {1.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
            withLabel: 'medium_medium' {memory = {8.GB * task.attempt}; time = {3.h * task.attempt}; maxRetries = 3; errorStrategy = 'retry' }
        }
    }

    dardel_test {
        process.executor       = 'slurm'
        process.queue          = 'shared'
        process.clusterOptions = "-A ${params.slurm_account}"
        conda.enabled          = true
        conda.useMamba         = params.use_mamba
        conda.cacheDir         = params.conda_cachedir
        process {
            withName: 'fastqc'              { memory = '2.GB';   cpus = 2 }
            withName: 'fastp'               { memory = '2.GB';   cpus = 2 }
            withName: 'bwa_mem'             { memory = '34.GB'; cpus = { params.bwa_threads }; time = '2.h'; queue = 'shared' }
            withName: 'bwa_mem_singlereads' { memory = '34.GB'; cpus = {params.bwa_threads}; time = '2.h'; queue = 'shared' }
            withName: 'bwa_index'           { memory = '16.GB';  cpus = 8; time = '2.h' }
            withName: 'samtools_markdups'   { memory = '2.GB' }
            withName: 'combine_bedfiles'    { memory = '2.GB' }
            withName: 'parse_region_depths' { memory = '2.GB' }
            withName: 'samtools_dp'         { memory = '2.GB' }
            withName: 'freebayes'             { memory = '4.GB'; time = '2.h' }
            withName: 'clumpify_single' { memory = '64.GB'; cpus = 8; time = '1.h'; queue = 'shared' }
            withName: 'clumpify_paired' { memory = '64.GB'; cpus = 8; time = '1.h'; queue = 'shared' }
            
        }
    }

    conda {
        conda.enabled = true
    }
}

// ── Execution reports ───────────────────────────────────────────────────────────

params.trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

timeline.enabled = true
timeline.file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_timestamp}.html"
    
report.enabled   = true
report.file      = "${params.outdir}/pipeline_info/execution_report_${params.trace_timestamp}.html"

trace.enabled    = true
trace.file       = "${params.outdir}/pipeline_info/execution_trace_${params.trace_timestamp}.txt"

// ── Manifest ────────────────────────────────────────────────────────────────────

manifest.name            = 'map_and_call'
manifest.author          = 'Axel Jensen'
manifest.description     = 'Nextflow pipeline for read mapping and variant calling'
manifest.mainScript      = 'main.nf'
manifest.nextflowVersion = '>=23.04.0'
manifest.version         = '0.1.0'
